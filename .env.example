# .env.example
# Security Warning: Do not commit your real .env file to version control!
# Copy this file to .env and fill in your details.

# Generate a strong, random secret key for production
SECRET_KEY=django-insecure-your-secret-key-here

# Must be False in production
DEBUG=False

# Domains allowed to serve the app
ALLOWED_HOSTS=localhost,127.0.0.1,musfiqur.pythonanywhere.com

# --- Database Configurations ---
# The project uses dj-database-url string formats.

# 1. Local SQLite fallback (if you don't have MySQL running locally)
# DATABASE_URL=sqlite:///db.sqlite3

# 2. Local MySQL (Default if left empty)
# DATABASE_URL=mysql://root:roo@localhost:3306/hotel

# 3. PythonAnywhere MySQL 
# Replace <PASSWORD> with your PythonAnywhere MySQL password.
# DATABASE_URL=mysql://musfiqur:<PASSWORD>@musfiqur.mysql.pythonanywhere-services.com/musfiqur$hotel
